# Copy to .harvey/LEGAL_RESEARCH.env and fill values locally (never commit secrets).
LEGAL_MODE=zero_byok_free_open
ENABLE_PAID_ESCALATION=0
PACER_BILLING_GUARD_ENABLED=1

WESTLAW_API_URL={{WESTLAW_API_URL}}
WESTLAW_API_KEY={{WESTLAW_API_KEY}}
LEXIS_API_URL={{LEXIS_API_URL}}
LEXIS_API_KEY={{LEXIS_API_KEY}}

COURTLISTENER_API_URL=https://www.courtlistener.com/api/rest/v4/search/
COURTLISTENER_API_TOKEN={{COURTLISTENER_API_TOKEN}}
RECAP_API_URL=https://www.courtlistener.com/api/rest/v4/dockets/

GOVINFO_API_URL={{GOVINFO_API_URL}}
GOVINFO_API_KEY={{GOVINFO_API_KEY}}

WORLDLII_SEARCH_URL={{WORLDLII_SEARCH_URL}}
BAILII_SEARCH_URL={{BAILII_SEARCH_URL}}
CORNELL_LII_SEARCH_URL={{CORNELL_LII_SEARCH_URL}}
CANLII_API_URL={{CANLII_API_URL}}
CANLII_API_KEY={{CANLII_API_KEY}}

MCP_TRANSPORT=stdio
