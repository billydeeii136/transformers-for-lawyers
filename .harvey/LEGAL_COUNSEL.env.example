# Copy to .harvey/LEGAL_COUNSEL.env and fill with retained counsel metadata (never commit private counsel data).
LICENSED_COUNSEL_REQUIRED=1
COUNSEL_ROSTER_PATH=.harvey/LICENSED_COUNSEL_ROSTER_TEMPLATE.yaml
COUNSEL_VERIFICATION_REQUIRED=1
EDNC_PRIMARY_COUNSEL={{EDNC_PRIMARY_COUNSEL}}
EDVA_PRIMARY_COUNSEL={{EDVA_PRIMARY_COUNSEL}}
NC_STATE_PRIMARY_COUNSEL={{NC_STATE_PRIMARY_COUNSEL}}
COUNSEL_NETWORK_PROVIDER={{COUNSEL_NETWORK_PROVIDER}}
