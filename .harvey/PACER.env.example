# Copy to .harvey/PACER.env and fill values locally (never commit secrets).
PACER_USERNAME={{PACER_USERNAME}}
PACER_PASSWORD={{PACER_PASSWORD}}
PACER_CLIENT_CODE=HARVEY_LEGAL_AUTOMATION
PACER_LOGIN_URL=https://pacer.login.uscourts.gov/csologin/login.jsf
PACER_MFA_MODE=manual
PACER_DEFAULT_COURTS=nced,vaed
PACER_SESSION_PATH=.harvey/runtime/pacer_session.json
